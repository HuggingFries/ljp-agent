{
  "api": {
    "base_url": "https://api.deepseek.com/v1",
    "api_key": "DEEPSEEK_API_KEY",
    "model_name": "deepseek-chat"
  },
  "retriever": {
    "mode": "hierarchical",
    "index_root": "data/index_by_charge",
    "coarse_k": 10,
    "positive": {
      "min_k": 1,
      "max_k": 5,
      "initial_candidates": 20,
      "step_add": 1
    },
    "negative": {
      "min_k": 1,
      "max_k": 5,
      "initial_candidates": 20,
      "step_add": 1
    }
  },
  "index": {
    "index_dir": "data",
    "embedding_model": "uer/sbert-base-chinese-nli"
  },
  "evaluation": {
    "test_file": "data/final_all_data/first_stage/test.json",
    "seed": 42
  },
  "logging": {
    "level": "INFO"
  }
}
